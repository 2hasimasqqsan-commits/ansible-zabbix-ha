totem {
    version: 2
    cluster_name: {{ cluster_name }}
    transport: knet

    # lab setting
    crypto_cipher: none
    crypto_hash: none
}

nodelist {
    node {
        ring0_addr: {{ zabbix_db01_ip }}
        name: zbx-ha-db01
        nodeid: 1
    }

    node {
        ring0_addr: {{ zabbix_db02_ip }}
        name: zbx-ha-db02
        nodeid: 2
    }
}

quorum {
    provider: corosync_votequorum
    two_node: 1
}

logging {
    to_logfile: yes
    logfile: /var/log/corosync/corosync.log
    to_syslog: yes
    timestamp: on
}
